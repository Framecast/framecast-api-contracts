#!/usr/bin/env bash
# Block accidental commits of generated code in gen/**.
# Generated code is owned by the Generate workflow (.github/workflows/generate.yml).
# Override for legitimate cases: ALLOW_GEN=1 git commit ...

set -euo pipefail

if [ "${ALLOW_GEN:-0}" = "1" ]; then
    exit 0
fi

staged_gen=$(git diff --cached --name-only --diff-filter=ACMRTD | grep -E '^gen/' || true)

if [ -n "$staged_gen" ]; then
    echo "✖ Refusing to commit changes under gen/**:" >&2
    echo "$staged_gen" | sed 's/^/  /' >&2
    echo >&2
    echo "gen/** is regenerated by .github/workflows/generate.yml on push to main." >&2
    echo "Edit proto/** instead and let CI regenerate." >&2
    echo >&2
    echo "If you really need to commit these files (e.g. bootstrapping the repo)," >&2
    echo "re-run with: ALLOW_GEN=1 git commit ..." >&2
    exit 1
fi
